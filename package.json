{
    "private": true,
    "scripts": {
        "dev": "npm run development",
        "development": "mix",
        "watch": "mix watch",
        "watch-poll": "mix watch -- --watch-options-poll=1000",
        "hot": "mix watch --hot",
        "prod": "npm run production",
        "production": "mix --production",
        "tailwind": "npx tailwindcss -i resources/css/app.css -o public/css/tailwind.css",
        "tailwind:watch": "npx tailwindcss -i resources/css/app.css -o public/css/tailwind.css --watch"
    },
    "devDependencies": {
        "autoprefixer": "^10.5.0",
        "axios": "^1.7.2",
        "html5-qrcode": "^2.3.8",
        "laravel-mix": "^6.0.6",
        "lodash": "^4.17.19",
        "postcss": "^8.5.15",
        "tailwindcss": "^3.4.19"
    }
}
